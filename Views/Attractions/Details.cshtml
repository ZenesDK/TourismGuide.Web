@model TourismGuide.Web.Models.Attraction

@{
    ViewData["Title"] = $"Информация о достопримечательности: {Model.Name}";
}

<h2>@Model.Name</h2>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Город</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.City.Name)</dd> <!-- Отображаем имя связанного города -->

            <dt class="col-sm-4">История</dt>
            <dd class="col-sm-8">@Html.DisplayFor(model => model.History)</dd>

            <dt class="col-sm-4">Часы работы</dt>
            <dd class="col-sm-8">@(Model.OpeningHours ?? "Не указаны")</dd> <!-- Показываем "Не указаны", если null -->

            <dt class="col-sm-4">Стоимость посещения</dt>
            <dd class="col-sm-8">
                @(Model.TicketPrice.HasValue ? Model.TicketPrice.Value.ToString("C") : "Бесплатно") <!-- Форматируем цену или показываем "Бесплатно" -->
            </dd>
        </dl>

        @if (!string.IsNullOrEmpty(Model.PhotoImageFileName))
        {
            <div class="mt-3">
                <h4>Фотография</h4>
                <img src="~/images/attractions/@Model.PhotoImageFileName"
                     alt="@Model.Name"
                     class="img-fluid rounded" />
            </div>
        }
    </div>
</div>

<hr />
<!-- Ссылка "Назад" ведёт на страницу деталей города, из которого пришли -->
<a asp-controller="Cities" asp-action="Details" asp-route-id="@Model.CityId" class="btn btn-outline-secondary">Вернуться к городу @Model.City?.Name</a>
<!-- Или можно сделать универсальную ссылку "Назад" -->
